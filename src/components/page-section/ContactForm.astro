---
const accessKey = import.meta.env.VITE_WEB3FORMS_ACCESS_KEY;
---

<!-- Contact Section Begin -->
<section class="contact-section spad" id="contact-us">
  <div class="container">
    <div class="row">
      <div class="col-lg-6">
        <div class="section-title contact-title">
          <span>Contact Us</span>
          <h2>GET IN TOUCH</h2>
        </div>
        <div class="contact-widget">
          <div class="cw-text">
            <i class="fa fa-map-marker"></i>
            <p>64 4 Ave W #26, Cardston, AB<br />T0K 0K0</p>
          </div>
          <div class="cw-text email">
            <i class="fa fa-envelope"></i>
            <p>windycitygymcardston@gmail.com</p>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="leave-comment">
          <form action="#" class="contact-us" data-access-key={accessKey}>
            <input type="text" placeholder="First Name" name="firstName" required />
            <input type="text" placeholder="Last Name" name="lastName" required />
            <input type="email" placeholder="Your Email" name="email" required />
            <textarea placeholder="Questions or Comments" name="message" required></textarea>
            <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
            <button type="submit">Send An Email</button>
          </form>
        </div>
      </div>
    </div>
    <div class="map">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d1658.3548990138454!2d-113.30246497477633!3d49.19679016541716!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x536f26d7d69bc6e1%3A0x2c367ed8f6bd711!2sWindy%20City%20Gym!5e1!3m2!1sen!2sca!4v1680214058619!5m2!1sen!2sca"
        height="550"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>
<!-- Contact Section End -->

<style>
  form input:focus,
  form textarea:focus {
    border: 2px solid orange !important;
  }
</style>

<script>
  import { submitToWeb3Forms } from "../../lib/web3forms";

  const forms = document.querySelectorAll(
    "form.contact-us"
  ) as NodeListOf<HTMLFormElement>;

  forms.forEach((form) => {
    form.addEventListener("submit", async (evt: Event) => {
      evt.preventDefault();
      const sub = form.querySelector("[type=submit]") as HTMLButtonElement;
      const accessKey = form.dataset.accessKey;
      sub.disabled = true;
      sub.textContent = "Sending...";

      const data = new FormData(form);
      const values = Object.fromEntries(data.entries()) as Record<string, string>;
      const name = [values.firstName, values.lastName].join(" ").trim();

      const payload: Record<string, string> = {
        name,
        email: values.email,
        message: values.message,
        subject: "New contact — Windy City Gym website",
        from_name: name,
        botcheck: values.botcheck || "",
      };

      const result = await submitToWeb3Forms(payload, accessKey);

      if (result.success) {
        sub.textContent = "Sent!";
        alert("Email Sent!");
        form.reset();
      } else {
        sub.textContent = "Error";
        alert(result.message || "Error Sending Email — Please Try Again Later");
      }

      setTimeout(() => {
        sub.disabled = false;
        sub.textContent = "Send An Email";
      }, 4000);
    });
  });
</script>